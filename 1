// test_queue.cpp
#include <gtest/gtest.h>
#include "queue.h"  // объявление Queue<T> с методами push(T), pop(), front(), empty(), size()

TEST(QueueTest, PushAndPopSingleElement) {
  Queue<int> q;
  q.push(42);
  ASSERT_FALSE(q.empty());
  EXPECT_EQ(q.front(), 42);
  EXPECT_EQ(q.size(), 1);
  q.pop();
  EXPECT_TRUE(q.empty());
  EXPECT_EQ(q.size(), 0);
}

TEST(QueueTest, PushMultipleElementsAndPopInOrder) {
  Queue<std::string> q;
  q.push("first");
  q.push("second");
  q.push("third");
  EXPECT_EQ(q.size(), 3);
  EXPECT_EQ(q.front(), "first");
  q.pop();
  EXPECT_EQ(q.front(), "second");
  q.pop();
  EXPECT_EQ(q.front(), "third");
  q.pop();
  EXPECT_TRUE(q.empty());
}

TEST(QueueTest, PopOnEmptyQueueBehavior) {
  Queue<double> q;
  // Поведение при pop на пустой очереди зависит от контракта класса.
  // Если класс гарантирует отсутствие падения (например, ничего не делает или выбрасывает исключение),
  // тест должен проверять именно это. Здесь предполагаем, что pop безопасен и ничего не делает.
  q.pop();
  EXPECT_TRUE(q.empty());
  EXPECT_EQ(q.size(), 0);
}
